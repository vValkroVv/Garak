{
  "rest": {
    "RestGenerator": {
      "name": "rag-summarizer-naive",
      "uri": "http://127.0.0.1:8002/generate",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "prompt": "$INPUT"
      },
      "response_json": true,
      "response_json_field": "text",
      "request_timeout": 120
    }
  }
}
